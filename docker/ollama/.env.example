# Path where Ollama stores models and configs.
#
# Convention: put all local AI-model dirs (Ollama, Whisper, Piper, LM Studio,
# …) under a shared parent like /mnt/<pool>/Applications/ai-models/<tool>/.
# Keeps the host filesystem tidy as you add more AI runtimes later and means
# there's one parent to back up / move around.
#
# Outside the synced obsidian-vaults tree so the multi-GB model files don't
# replicate to other devices.
OLLAMA_DATA_DIR=/mnt/HDDs/Applications/ai-models/ollama
