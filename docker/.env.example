# Copy to .env and fill in your secrets.
# .env is gitignored — never commit real values.

# ── Required: Discord bot token ─────────────────────────────────────────────
# Create one at https://discord.com/developers/applications
# Required scopes: bot, applications.commands
# Required intents: MESSAGE_CONTENT, MESSAGES, GUILDS
DISCORD_BOT_TOKEN=

# ── Required for Dockge (or any place outside the repo's docker/ folder) ────
# Absolute path to the obsidian-iris-mcp/ repo on the host. Used as the Docker
# build context. Leave commented if running compose from inside docker/.
# IRIS_REPO_DIR=/mnt/tank/syncthing/obsidian-vaults/obsidian-iris-mcp

# Absolute path to the AI_Memory vault on the host.
# IRIS_VAULT_DIR=/mnt/tank/syncthing/obsidian-vaults/AI_Memory

# ── Required: Claude CLI auth directory (persists between restarts) ────────
# Default is ./claude-auth alongside the compose file. Override if you want
# the token directory elsewhere (e.g. a TrueNAS dataset outside the synced
# repo so it's not accidentally replicated to the Mac).
# IRIS_AUTH_DIR=/mnt/tank/iris-discord/claude-auth

# ── Optional bot config ────────────────────────────────────────────────────
# Restrict to specific Discord channels (CSV of channel IDs).
IRIS_DISCORD_ALLOWED_CHANNELS=

# Restrict to specific users (CSV of user IDs).
IRIS_DISCORD_ALLOWED_USERS=

# Channels where Iris responds to every human message (no @-mention needed).
# Use this for dedicated Iris channels like #iris-tasks, #iris-notes, etc.
# DMs are always treated this way regardless of this setting.
# To get a channel ID: enable Developer Mode in Discord (Settings → Advanced),
# then right-click the channel → Copy Channel ID.
IRIS_DISCORD_LISTEN_ALWAYS_CHANNELS=

# ── Proactive notifications ────────────────────────────────────────────────
# Channel where Iris posts unsolicited pings — upcoming events, reminders,
# morning briefing, evening wrap-up, and snooze replays.
# Leave blank to disable all proactive output.
# (Legacy alias IRIS_DISCORD_NOTIFY_CHANNEL still works.)
IRIS_DISCORD_PING_CHANNEL=

# How often (seconds) the bot scans the vault for new things to ping about.
# IRIS_NOTIFY_INTERVAL_SECS=300

# Lead time before an event/reminder for the ping. Default 15.
# IRIS_NOTIFY_LEAD_MIN=15

# Time of day for the daily morning briefing (HH:MM, 24h). Set to "off" to skip.
# IRIS_NOTIFY_MORNING_AT=08:00

# Time of day for the daily evening wrap-up. Set to "off" to skip.
# IRIS_NOTIFY_EVENING_AT=22:00

# Model override (defaults to claude-sonnet-4-6 from the image).
# IRIS_DISCORD_MODEL=claude-sonnet-4-6
