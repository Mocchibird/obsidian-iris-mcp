# Copy to .env and fill in your secrets.
# .env is gitignored — never commit real values.

# Discord bot token — create one at https://discord.com/developers/applications
# Required scopes: bot, applications.commands
# Required intents: MESSAGE_CONTENT, MESSAGES, GUILDS
DISCORD_BOT_TOKEN=

# Optional: restrict the bot to specific Discord channels (comma-separated IDs).
# If unset, the bot responds in any channel it can see.
IRIS_DISCORD_ALLOWED_CHANNELS=

# Optional: restrict to specific Discord users (comma-separated user IDs).
# If unset, anyone in the allowed channels can talk to it.
IRIS_DISCORD_ALLOWED_USERS=

# Optional: model override (defaults to claude-sonnet-4-6 from the image).
# IRIS_DISCORD_MODEL=claude-sonnet-4-6
