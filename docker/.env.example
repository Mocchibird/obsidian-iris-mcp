# Copy to .env and fill in your secrets.
# .env is gitignored — never commit real values.

# ── Required: Discord bot token ─────────────────────────────────────────────
# Create one at https://discord.com/developers/applications
# Required scopes: bot, applications.commands
# Required intents: MESSAGE_CONTENT, MESSAGES, GUILDS
DISCORD_BOT_TOKEN=

# ── Required for Dockge (or any place outside the repo's docker/ folder) ────
# Absolute path to the obsidian-iris-mcp/ repo on the host. Used as the Docker
# build context. Leave commented if running compose from inside docker/.
# IRIS_REPO_DIR=/mnt/tank/syncthing/obsidian-vaults/obsidian-iris-mcp

# Absolute path to the AI_Memory vault on the host.
# IRIS_VAULT_DIR=/mnt/tank/syncthing/obsidian-vaults/AI_Memory

# ── Required: Claude CLI auth directory (persists between restarts) ────────
# Default is ./claude-auth alongside the compose file. Override if you want
# the token directory elsewhere (e.g. a TrueNAS dataset outside the synced
# repo so it's not accidentally replicated to the Mac).
# IRIS_AUTH_DIR=/mnt/tank/iris-discord/claude-auth

# ── Optional bot config ────────────────────────────────────────────────────
# Restrict to specific Discord channels (CSV of channel IDs).
IRIS_DISCORD_ALLOWED_CHANNELS=

# Restrict to specific users (CSV of user IDs).
IRIS_DISCORD_ALLOWED_USERS=

# Channels where Iris responds to every human message (no @-mention needed).
# Use this for dedicated Iris channels like #iris-tasks, #iris-notes, etc.
# DMs are always treated this way regardless of this setting.
# To get a channel ID: enable Developer Mode in Discord (Settings → Advanced),
# then right-click the channel → Copy Channel ID.
IRIS_DISCORD_LISTEN_ALWAYS_CHANNELS=

# Max messages that can stack up per channel while Iris is still working on
# the previous one. Beyond this, new messages are rejected with a "queue
# full" reply (otherwise you'd be waiting forever for a runaway pile to
# drain). Each queued message gets a 📥 reaction; the reaction is removed
# when Iris starts processing that message.
# IRIS_DISCORD_MAX_QUEUE_DEPTH=5

# How many minutes of recent Discord channel history to inject into a fresh
# Claude session as context. Lets conversations feel continuous across bot
# restarts without persisting Claude sessions to disk. The vault stays the
# canonical long-term memory; Discord history is short-term. Set to 0 to
# disable (each restart = clean slate).
# IRIS_DISCORD_CONTEXT_MINUTES=60

# Soft token budget for the recent-history injection. Selection is fuzzy and
# snaps to "conversation burst" boundaries (see _BURST_GAP_MIN below) so a
# coherent topic is never cut in half — even if doing so overshoots the soft
# budget by up to FUZZ_FACTOR.
# IRIS_DISCORD_CONTEXT_TOKEN_BUDGET=2000

# How much the selector is willing to overshoot the soft budget for a single
# topic burst. 1.5 means the hard ceiling is 1.5× soft budget. Bumps up to
# (say) 2.0 if you'd rather keep more whole topics at the cost of some prompt.
# IRIS_DISCORD_CONTEXT_FUZZ_FACTOR=1.5

# Minutes between two messages that count as ENDING one burst and starting
# another. Larger = more aggressive grouping. Default 10 ≈ a coherent
# sitting at the keyboard.
# IRIS_DISCORD_CONTEXT_BURST_GAP_MIN=10

# Where the bot writes its per-channel JSONL history log. The Iris MCP
# server reads this via the fetch_discord_history tool when Iris needs to
# look further back than the cold-start context window.
# IRIS_DISCORD_HISTORY_DIR=/claude-auth/discord-channels

# Completion ping: after Iris finishes a streamed reply, send a tiny
# auto-deleting message so Discord plays its new-message notification
# sound. (Edits to the placeholder during streaming don't notify.)
# Set to off / 0 / false to disable. Default: on.
# IRIS_DISCORD_COMPLETION_PING=on
# IRIS_DISCORD_COMPLETION_PING_EMOJI=✓
# IRIS_DISCORD_COMPLETION_PING_TTL=4         # seconds before auto-delete; 0 = keep forever

# ── Proactive notifications ────────────────────────────────────────────────
# Channel where Iris posts unsolicited pings — upcoming events, reminders,
# morning briefing, evening wrap-up, and snooze replays.
# Leave blank to disable all proactive output.
# (Legacy alias IRIS_DISCORD_NOTIFY_CHANNEL still works.)
IRIS_DISCORD_PING_CHANNEL=

# How often (seconds) the bot scans the vault for new things to ping about.
# Default 60 = minute precision. Increase if you want lower CPU/IO at the cost
# of pings landing up to N seconds after the target minute.
# IRIS_NOTIFY_INTERVAL_SECS=60

# Lead time before an event/reminder for the ping. Default 15.
# IRIS_NOTIFY_LEAD_MIN=15

# Time of day for the daily morning briefing (HH:MM, 24h). Set to "off" to skip.
# IRIS_NOTIFY_MORNING_AT=08:00

# Time of day for the daily evening wrap-up. Set to "off" to skip.
# IRIS_NOTIFY_EVENING_AT=22:00

# Catch-up grace windows: if the bot restarts AFTER the scheduled time but
# within N minutes of it, still fire the briefing on this run. Past the
# window, suppress until tomorrow. Defaults: 180 min for morning (08:00 fires
# until 11:00), 60 min for evening (22:00 fires until 23:00). Tune to taste.
# IRIS_NOTIFY_MORNING_GRACE_MIN=180
# IRIS_NOTIFY_EVENING_GRACE_MIN=60

# Default timezone for the container (affects logs + naive datetime arithmetic).
# Per-day overrides come from the daily note's `timezone:` frontmatter — useful
# when travelling so 08:00 always means 08:00 *local* wherever you are.
TZ=Europe/Zurich
# Optional: explicit "home" timezone for Iris if different from container TZ.
# IRIS_TIMEZONE=Europe/Zurich

# Model override (defaults to claude-sonnet-4-6 from the image).
# IRIS_DISCORD_MODEL=claude-sonnet-4-6

# Default iCal subscription URL(s) for the `sync_all_calendars` MCP tool.
# When you ask Iris to "sync my calendar" without specifying a URL, she
# walks this list, syncing each feed in order. Each feed: a URL plus
# optional semicolon-separated key=value params.
#
# Format: URL[;tag=...][;person=...][;dedupe=...]   pipe-separated for multi
#
# Supported params per feed:
#   tag=<label>      Source tag stored in event description for filtering.
#                    Defaults to "ical". Examples: icloud-personal, work,
#                    family, marimo.
#   person=<path>    Vault path to a person note. Every event imported from
#                    this feed gets `with: [[<path>]]` added to its
#                    description — so the contact's profile auto-backlinks
#                    every event of theirs you've synced. Useful for a
#                    partner's shared calendar.
#   dedupe=uid       Disable cross-calendar (date+time+title) dedupe for
#                    this feed. Default is content-aware (catches the same
#                    meeting appearing in multiple calendars with different
#                    UIDs).
#
# Example with three feeds — personal first (authoritative), work second
# (skip dups), partner's calendar with auto-backlink to her profile:
#
#   IRIS_DEFAULT_ICAL_URLS=webcal://p01-caldav.icloud.com/.../personal.ics;tag=icloud-personal|https://calendar.google.com/.../basic.ics;tag=work|webcal://p01-caldav.icloud.com/.../marimo.ics;tag=marimo;person=10_Profile/People/Marimo Honda
#
# Accepts `webcal://` (auto-rewritten to https://). Public feed only —
# share/publish your calendar first to get the URL. No auth supported.
# IRIS_DEFAULT_ICAL_URLS=

# How often (minutes) the bot pulls iCal feeds in the background. Default
# 60 = hourly. Set 0 to disable (sync then only runs via the morning brief
# or when explicitly asked). Lower (15-30) if your calendars change a lot
# and you want event pings to catch last-minute additions. Set to 0 if
# your feeds are slow / you don't care about same-day freshness.
# IRIS_ICAL_SYNC_INTERVAL_MIN=60

# How often (minutes) to snapshot the live vault SQLite DB to a sync-safe
# copy. Iris's live `vault.db` uses WAL mode (multi-file, mid-transaction
# states) which races with syncthing. The snapshot is produced via
# `VACUUM INTO` — atomic, single-file, committed-state-only — and lands
# at `<vault>/.ai_memory_cache/vault-snapshot.db`. Point your Obsidian
# SQLite-DB plugin on read-only devices (Mac / Windows) at this snapshot.
# Default 10 min = ~10-minute read-only-side staleness. Set 0 to disable
# entirely. Cheap CPU-wise even at 1-2 min for big vaults.
# IRIS_VAULT_SNAPSHOT_INTERVAL_MIN=10

# How often (minutes) to re-render ```sqlite code blocks in vault notes
# into plain markdown tables. The Obsidian SQLite-DB plugin doesn't run
# on iOS/iPadOS (no native Node modules on iOS) — pre-rendering server-
# side makes the same data visible on every device. Wraps the rendered
# table in HTML comments (`<!-- iris-sql-result … -->`) so refreshes
# replace the previous output idempotently instead of duplicating it.
# Default 15. Set 0 to disable (only refreshed when explicitly asked
# via `refresh_sql_views` in chat).
# IRIS_SQL_VIEW_REFRESH_MIN=15

# Obsidian vault name (the folder basename of IRIS_VAULT_DIR — for
# /mnt/.../obsidian-vaults/AI_Memory that's `AI_Memory`). Used by your
# https redirector (see next var); the bot itself doesn't need it.
# IRIS_OBSIDIAN_VAULT_NAME=AI_Memory

# HTTPS prefix of a redirector you host that 302s to obsidian://.
# WHY: Discord doesn't render `obsidian://...` as a clickable link — not
# bare, not as `[label](obsidian://...)`. Their scheme allowlist is
# http/https/ftp/discord/skype/etc. So to get clickable note links in
# Discord, the bot has to emit https URLs that bounce to obsidian:// on
# YOUR server. Without this var set, wikilinks render as plain display
# names (still readable, just not clickable).
#
# Example using a subdomain of your own domain:
#   IRIS_OBSIDIAN_URL_PREFIX=https://o.example.com
#
# Caddy config on your redirector host (one block, drop-in):
#   o.example.com {
#       redir "obsidian://open?vault=AI_Memory&file={path}" 302
#   }
# (Replace AI_Memory with your vault name. Caddy auto-handles TLS.)
#
# Or nginx equivalent:
#   server {
#       listen 443 ssl;
#       server_name o.example.com;
#       location / {
#           rewrite ^/(.*)$ "obsidian://open?vault=AI_Memory&file=$1" redirect;
#       }
#   }
# IRIS_OBSIDIAN_URL_PREFIX=https://o.example.com
